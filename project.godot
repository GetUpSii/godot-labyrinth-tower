; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="mota3000"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SignalManager="*res://global/SignalManager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
LevelManager="*res://global/LevelManager.gd"
CharacterLoader="*res://global/character_loader.gd"
Global="*res://global/Global.gd"
ItemLoader="*res://global/item_loader.gd"
SaveSystem="*res://global/SaveSystem.gd"
SceneLoader="*res://global/SceneLoader.gd"
LogManager="*res://global/LogManager.gd"
Focus="*res://global/focus.gd"
EffectExecutor="*res://component/effect/effect_executor.gd"
GUIDE="*res://addons/guide/guide.gd"
SkillLoader="*res://component/skill/skill_loader.gd"
BattleSystem="*res://global/BattleSystem.gd"
InputManager="*res://global/InputManager.gd"
CraftLoader="*res://component/craft/craft_loader.gd"
SequenceDialoguePlayer="*res://component/effect/sequence_dialogue_player.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=576
window/size/viewport_height=324
window/size/window_width_override=1152
window/size/window_height_override=648
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/guide/plugin.cfg", "res://addons/simple_gdscript_formatter/plugin.cfg")

[global_group]

enemy=""
player=""
item=""
door=""
npc=""
trap=""
secret_step=""
shelf=""

